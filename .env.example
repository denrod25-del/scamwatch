# ScamWatch environment — copy to .env.local and fill in. NEVER commit real values.
# Secrets management & rotation policy: see Volume 14 (Security) and Volume 13 (Backend).

# --- Supabase (Vol 13) ---
# Public — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
# Server-only — full DB access, bypasses RLS. MUST stay server-side. Never NEXT_PUBLIC_*.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_DB_URL="postgresql://postgres:postgres@localhost:54322/postgres"

# --- OpenAI / AI Intelligence Engine (Vol 8) ---
# Server-only. De-identify content before sending (SEC-14 / AI-8). Use a data-retention-off org.
OPENAI_API_KEY="your-openai-key"
OPENAI_MODEL_CLASSIFIER="gpt-4o-mini"
OPENAI_MODEL_EXPLAINER="gpt-4o"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"

# --- App ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_ENV="development"

# --- Notifications (Vol 13, provider-abstracted) ---
# EMAIL_PROVIDER_API_KEY=""

# --- Report-processing worker (Vol 8/13) ---
# Shared secret for the internal /api/internal/process endpoint. Vercel Cron sends
# it as `Authorization: Bearer $CRON_SECRET`. Generate: openssl rand -hex 32
CRON_SECRET=""

# --- Observability (Vol 17) ---
# SENTRY_DSN=""
